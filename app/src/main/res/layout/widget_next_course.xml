<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget2_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_2x2"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/tv_widget2_badge"
        android:layout_width="wrap_content"
        android:layout_height="24dp"
        android:background="@drawable/widget_time_chip"
        android:gravity="center"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:text="接下来"
        android:textColor="@color/text_primary"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_widget2_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/text_secondary"
        android:textSize="11sp" />

    <TextView
        android:id="@+id/tv_widget2_empty"
        android:layout_width="match_parent"
        android:layout_height="34dp"
        android:layout_marginTop="12dp"
        android:gravity="center_vertical"
        android:text="今天后面没有课"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/widget2_course_1"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">
        <View android:id="@+id/widget2_course_color_1" android:layout_width="4dp" android:layout_height="30dp" android:background="#5B8DEF" />
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginLeft="8dp" android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/widget2_course_name_1" android:layout_width="match_parent" android:layout_height="wrap_content" android:ellipsize="end" android:maxLines="1" android:textColor="@color/text_primary" android:textSize="13sp" android:textStyle="bold" />
            <TextView android:id="@+id/widget2_course_info_1" android:layout_width="match_parent" android:layout_height="wrap_content" android:ellipsize="end" android:maxLines="1" android:textColor="@color/text_secondary" android:textSize="10sp" />
        </LinearLayout>
        <TextView android:id="@+id/widget2_course_time_1" android:layout_width="72dp" android:layout_height="wrap_content" android:gravity="right" android:textColor="@color/text_secondary" android:textSize="10sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget2_course_2"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">
        <View android:id="@+id/widget2_course_color_2" android:layout_width="4dp" android:layout_height="30dp" android:background="#5B8DEF" />
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginLeft="8dp" android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/widget2_course_name_2" android:layout_width="match_parent" android:layout_height="wrap_content" android:ellipsize="end" android:maxLines="1" android:textColor="@color/text_primary" android:textSize="13sp" android:textStyle="bold" />
            <TextView android:id="@+id/widget2_course_info_2" android:layout_width="match_parent" android:layout_height="wrap_content" android:ellipsize="end" android:maxLines="1" android:textColor="@color/text_secondary" android:textSize="10sp" />
        </LinearLayout>
        <TextView android:id="@+id/widget2_course_time_2" android:layout_width="72dp" android:layout_height="wrap_content" android:gravity="right" android:textColor="@color/text_secondary" android:textSize="10sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget2_course_3"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">
        <View android:id="@+id/widget2_course_color_3" android:layout_width="4dp" android:layout_height="30dp" android:background="#5B8DEF" />
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginLeft="8dp" android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/widget2_course_name_3" android:layout_width="match_parent" android:layout_height="wrap_content" android:ellipsize="end" android:maxLines="1" android:textColor="@color/text_primary" android:textSize="13sp" android:textStyle="bold" />
            <TextView android:id="@+id/widget2_course_info_3" android:layout_width="match_parent" android:layout_height="wrap_content" android:ellipsize="end" android:maxLines="1" android:textColor="@color/text_secondary" android:textSize="10sp" />
        </LinearLayout>
        <TextView android:id="@+id/widget2_course_time_3" android:layout_width="72dp" android:layout_height="wrap_content" android:gravity="right" android:textColor="@color/text_secondary" android:textSize="10sp" />
    </LinearLayout>
</LinearLayout>
