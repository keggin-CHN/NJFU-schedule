<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <application
        android:name=".App"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.NJFUSchedule"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".ui.schedule.ScheduleActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.import_.ImportActivity"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.import_.AddCourseActivity"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.settings.ScheduleSettingsActivity"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.settings.TimeSettingsActivity"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.settings.BackgroundSettingsActivity"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.settings.AboutActivity"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.settings.WebViewActivity"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize" />

        <!-- 今日课程桌面小组件 (4x1) -->
        <receiver
            android:name=".widget.TodayCourseWidget"
            android:exported="true"
            android:label="今日课程">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="android.intent.action.TIME_SET" />
                <action android:name="android.intent.action.DATE_CHANGED" />
                <action android:name="com.njfu.schedule.REFRESH_WIDGET" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_today_info" />
        </receiver>

        <!-- 下节课小组件 (2x2) -->
        <receiver
            android:name=".widget.NextCourseWidget"
            android:exported="true"
            android:label="下节课">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="android.intent.action.TIME_SET" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_next_course_info" />
        </receiver>

    </application>
</manifest>
