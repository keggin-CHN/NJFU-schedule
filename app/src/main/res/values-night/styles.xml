<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.NJFU.ChoiceChip" parent="Widget.Material3.Chip.Filter">
        <item name="checkedIconVisible">false</item>
        <item name="chipMinHeight">36dp</item>
        <item name="chipBackgroundColor">@color/chip_bg</item>
        <item name="chipStrokeColor">@color/chip_stroke</item>
        <item name="android:textColor">@color/chip_text</item>
    </style>

    <style name="Widget.NJFU.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/field_stroke</item>
        <item name="boxStrokeWidth">2dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxBackgroundColor">@color/background</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
    </style>
</resources>