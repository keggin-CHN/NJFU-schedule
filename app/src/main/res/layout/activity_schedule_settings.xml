<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/surface"
        android:elevation="2dp"
        app:navigationIcon="@drawable/ic_back"
        app:title="课表设置"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 课表名称 -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="课表名称" android:textSize="16sp" android:textStyle="bold" />
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_table_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="南林课表" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" android:layout_marginTop="16dp" android:layout_marginBottom="16dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="课表数据" android:textSize="14sp" android:textColor="@color/text_secondary" />

            <!-- 第一周第一天 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="48dp" android:gravity="center_vertical" android:layout_marginTop="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="第一周的第一天" android:textSize="15sp" />
                <TextView android:id="@+id/tv_start_date" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/text_secondary" android:textSize="14sp" />
            </LinearLayout>

            <!-- 当前周 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="48dp" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="当前周" android:textSize="15sp" />
                <TextView android:id="@+id/tv_current_week" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="?colorPrimary" android:textSize="14sp" />
            </LinearLayout>

            <!-- 每天节数 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="48dp" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="一天课程节数" android:textSize="15sp" />
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_nodes"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:inputType="number"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- 学期周数 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="48dp" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="学期周数" android:textSize="15sp" />
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_max_week"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:inputType="number"
                    android:textSize="14sp" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" android:layout_marginTop="16dp" android:layout_marginBottom="16dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="课表外观" android:textSize="14sp" android:textColor="@color/text_secondary" />

            <!-- 显示周六 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="48dp" android:gravity="center_vertical" android:layout_marginTop="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="显示周六" android:textSize="15sp" />
                <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/switch_sat" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- 显示周日 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="48dp" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="显示周日" android:textSize="15sp" />
                <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/switch_sun" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- 显示非本周课程 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="48dp" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="显示非本周课程" android:textSize="15sp" />
                <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/switch_other_week" android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true" />
            </LinearLayout>

            <!-- 保存按钮 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="24dp"
                android:text="保存设置" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
